# ==============================================================================
# Local RAG Chatbot — Environment Configuration
# ==============================================================================
# Copy this file to .env and update values as needed.
# All values shown are development defaults.
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=console
# "console" for pretty dev output, "json" for production structured logs

# ------------------------------------------------------------------------------
# Backend (FastAPI)
# ------------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
# In production, set workers = (2 * CPU cores) + 1

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# API key for simple auth (single-user mode)
API_KEY=dev-api-key-change-in-production

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=rag_chatbot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Constructed automatically in app — shown here for reference:
# DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@postgres:5432/rag_chatbot

# ------------------------------------------------------------------------------
# Qdrant (Vector Database)
# ------------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=documents

# ------------------------------------------------------------------------------
# Ollama (LLM)
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_TIMEOUT=120
# Timeout in seconds — generation can be slow on CPU

# LLM parameters
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048

# ------------------------------------------------------------------------------
# Embedding Model (BGE-M3)
# ------------------------------------------------------------------------------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# Set to "cuda" if you have an NVIDIA GPU
EMBEDDING_BATCH_SIZE=32
EMBEDDING_USE_FP16=false
# Set to true if using GPU for faster inference

# ------------------------------------------------------------------------------
# Reranker Model (BGE-Reranker-v2-m3)
# ------------------------------------------------------------------------------
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_USE_FP16=false

# ------------------------------------------------------------------------------
# RAG Pipeline
# ------------------------------------------------------------------------------
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVAL_TOP_K=20
RAG_RERANK_TOP_K=5

# ------------------------------------------------------------------------------
# Document Upload
# ------------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=pdf,docx,pptx,txt,md,html

# ------------------------------------------------------------------------------
# Frontend (Next.js)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
